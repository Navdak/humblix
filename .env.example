APP_NAME="HUMELIX LIMITED"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=https://humelix.com

# Required before running production seeders.
HUMELIX_SUPER_ADMIN_EMAIL=developer@example.com
HUMELIX_SUPER_ADMIN_PASSWORD=change_this_to_a_strong_unique_password

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=warning

# Database - replace placeholders with production credentials.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=humelix_systems
DB_USERNAME=humelix_user
DB_PASSWORD=change_me

FILESYSTEM_DISK=public
# Use "database" in production with the jobs table migrated and a queue cron/worker running.
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
CACHE_STORE=file

# Mail - use real production SMTP values on the server, never commit secrets.
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=change_me
MAIL_PASSWORD=change_me
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@humelix.com"
MAIL_FROM_NAME="HUMELIX LIMITED"

# TinyMCE Cloud - set this in production/Render environment variables.
TINYMCE_API_KEY=your_tinymce_api_key_here
